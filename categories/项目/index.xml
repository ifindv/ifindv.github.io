&lt;/span>&lt;span class="lnt"> 7
&lt;/span>&lt;span class="lnt"> 8
&lt;/span>&lt;span class="lnt"> 9
&lt;/span>&lt;span class="lnt">10
&lt;/span>&lt;span class="lnt">11
&lt;/span>&lt;span class="lnt">12
&lt;/span>&lt;span class="lnt">13
&lt;/span>&lt;span class="lnt">14
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-gdscript3" data-lang="gdscript3">&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># ethtool -S em2&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="n">NIC&lt;/span> &lt;span class="n">statistics&lt;/span>&lt;span class="p">:&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">rx_packets&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">35430208463&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">tx_packets&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">216072&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">rx_bytes&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">32454370137414&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">tx_bytes&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">53624450&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">rx_broadcast&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">17424355&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">tx_broadcast&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">133508&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">rx_multicast&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">5332175&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">tx_multicast&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">82564&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">rx_errors&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">47&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="n">tx_errors&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">0&lt;/span>
